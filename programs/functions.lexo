# Functions with typed parameters and return types
def greet(name: string) -> string:
    return "Hello, " + name + "!"

def add(a: int, b: int) -> int:
    return a + b

def factorial(n: int) -> int:
    if n <= 1:
        return 1
    return n * factorial(n - 1)

print(greet("World"))
print(add(3, 4))
print(factorial(6))
